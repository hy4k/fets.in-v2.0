# Copy to .env and fill in (required for Supabase: bookings, early access, admin slots).
# Vite only exposes variables prefixed with VITE_. Rebuild after changing.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional
# VITE_ADMIN_PASSWORD=

# ── PayU Payment Gateway ──────────────────────────────────────────────────
# PayU credentials are stored SERVER-SIDE as Supabase Edge Function secrets.
# To configure, run in the Supabase CLI:
#   supabase secrets set PAYU_MERCHANT_KEY=your_merchant_key
#   supabase secrets set PAYU_MERCHANT_SALT=your_merchant_salt
#   supabase secrets set PAYU_BASE_URL=https://secure.payu.in   (production)
#   supabase secrets set PAYU_BASE_URL=https://test.payu.in      (sandbox)
#   supabase secrets set SITE_URL=https://fets.in
# These are NEVER exposed to the frontend for security.
